# --- Server ---
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:5173

# --- Database ---
# Local Docker Mongo (see docker-compose.yml). For Atlas, paste your SRV URI.
MONGO_URI=mongodb://localhost:27017/teamboard

# --- Auth ---
# Use a long random string in real environments (min 16 chars).
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# Password assigned to users created via a project invite (they log in with it).
DEFAULT_INVITE_PASSWORD=TeamBoard123!

# --- Events (optional) ---
# If set, cross-module domain events (e.g. project.deleted) are published over
# Redis pub/sub. If unset, an in-process event bus is used instead.
REDIS_URL=redis://localhost:6379

# --- Rate limiting ---
# Max THROTTLE_LIMIT requests per THROTTLE_TTL seconds, per IP.
THROTTLE_TTL=60
THROTTLE_LIMIT=100
