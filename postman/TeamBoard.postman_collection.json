{
  "info": {
    "name": "TeamBoard API",
    "description": "TeamBoard backend (NestJS). Run requests top-to-bottom: Signup/Login auto-saves the JWT to {{accessToken}}; creating a project auto-saves {{projectId}}; creating a task auto-saves {{taskId}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "accessToken", "value": "" },
    { "key": "projectId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "memberUserId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Dashboard",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/dashboard"
      }
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "List Members",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}/members"
          }
        },
        {
          "name": "Invite Member",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.member && res.member.id) { pm.collectionVariables.set('memberUserId', res.member.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"teammate@example.com\"\n}"
            },
            "url": "{{baseUrl}}/projects/{{projectId}}/members"
          }
        },
        {
          "name": "Remove Member",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/projects/{{projectId}}/members/{{memberUserId}}"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) { pm.collectionVariables.set('accessToken', res.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ada Lovelace\",\n  \"email\": \"ada@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/signup"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.accessToken) { pm.collectionVariables.set('accessToken', res.accessToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ada@example.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) { pm.collectionVariables.set('projectId', res._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Website Redesign\",\n  \"description\": \"Q3 marketing site refresh\"\n}"
            },
            "url": "{{baseUrl}}/projects"
          }
        },
        {
          "name": "List Projects",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/projects" }
        },
        {
          "name": "Get Project",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/projects/{{projectId}}" }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated scope\"\n}"
            },
            "url": "{{baseUrl}}/projects/{{projectId}}"
          }
        },
        {
          "name": "Delete Project",
          "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/projects/{{projectId}}" }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res._id) { pm.collectionVariables.set('taskId', res._id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Design homepage\",\n  \"description\": \"Wireframe + hi-fi\",\n  \"status\": \"todo\"\n}"
            },
            "url": "{{baseUrl}}/projects/{{projectId}}/tasks"
          }
        },
        {
          "name": "List Project Tasks",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/projects/{{projectId}}/tasks" }
        },
        {
          "name": "Get Task",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/tasks/{{taskId}}" }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in_progress\"\n}"
            },
            "url": "{{baseUrl}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Delete Task",
          "request": { "method": "DELETE", "header": [], "url": "{{baseUrl}}/tasks/{{taskId}}" }
        }
      ]
    }
  ]
}
